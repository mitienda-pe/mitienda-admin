# API Configuration
# Para desarrollo local, usar proxy de Vite para evitar CORS:
VITE_API_BASE_URL=/api/v1
# Para producción, usar URL completa:
# VITE_API_BASE_URL=https://api.mitienda.pe/api/v1

# CDN URL para imágenes
VITE_CDN_URL=https://cdn.mitienda.pe

# Sentry error tracking (dejar vacío para deshabilitar)
VITE_SENTRY_DSN=

# Credenciales de prueba (solo para desarrollo)
VITE_TEST_EMAIL=
VITE_TEST_PASSWORD=

# OneSignal Web Push
VITE_ONESIGNAL_APP_ID=

# WhatsApp Business Integration (Embedded Signup)
# App ID: same as WHATSAPP_APP_ID in the CI4 backend
# Config ID: from Meta Developer Console → WhatsApp → Embedded Signup configuration
VITE_WHATSAPP_APP_ID=your_meta_app_id
VITE_WHATSAPP_CONFIG_ID=your_embedded_signup_config_id
